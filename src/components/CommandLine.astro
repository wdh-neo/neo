---
interface Props {
  command: string;
  /** Animate the command being typed on first paint. Defaults to true. */
  animate?: boolean;
  /** Override the prompt prefix (default `$`). */
  prompt?: string;
}
const { command, animate = true, prompt = "$" } = Astro.props;
const charCount = command.length;
const typeDuration = `${Math.max(0.6, charCount * 0.06)}s`;
---

<div class={`cmdline${animate ? " cmdline--animate" : ""}`}>
  <div class="line"
    ><span class="prompt" aria-hidden="true">{prompt}</span
    ><span
      class="command"
      style={`--char-count: ${charCount}; --type-duration: ${typeDuration};`}
    >{command}</span><span class="cursor" aria-hidden="true">▌</span></div>
  <button
    type="button"
    class="copy"
    data-cmd={command}
    aria-label="Copy command"
    title="Copy command"
  >
    <svg class="copy__icon copy__icon--default" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
      <rect x="4.5" y="4.5" width="9" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
      <path d="M2.5 11V3.5A1 1 0 0 1 3.5 2.5H11" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
    <svg class="copy__icon copy__icon--ok" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
      <path d="M3 8.5l3 3 7-7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  {Astro.slots.has("default") && (
    <div class="output"><slot /></div>
  )}
</div>

<style>
  .cmdline {
    font-family: var(--mono);
    font-size: 0.95rem;
    color: var(--fg);
    background: var(--bg-elev);
    border: 1px solid var(--accent-2);
    border-radius: var(--radius);
    padding: 0.85rem 3rem 0.85rem 1rem;
    position: relative;
  }

  .line {
    white-space: nowrap;
    overflow: hidden;
  }

  .prompt {
    color: var(--accent);
    margin-right: 0.5em;
    font-weight: 600;
  }

  .command {
    display: inline-block;
    vertical-align: bottom;
    white-space: nowrap;
    overflow: hidden;
  }

  .cmdline--animate .command {
    width: 0;
    animation: typewriter var(--type-duration) steps(var(--char-count)) 0.4s forwards;
  }

  .cursor {
    display: inline-block;
    color: var(--accent-strong);
    margin-left: 2px;
    vertical-align: bottom;
    animation: blink 1.05s steps(1, end) infinite;
  }

  .copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: 1px solid var(--accent-2);
    border-radius: 6px;
    background: transparent;
    color: var(--accent-2);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .copy:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .copy:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .copy__icon--ok { display: none; color: var(--success); }
  .copy.copy--ok { color: var(--success); border-color: var(--success); }
  .copy.copy--ok .copy__icon--default { display: none; }
  .copy.copy--ok .copy__icon--ok { display: inline-block; }

  .output {
    margin-top: 0.6rem;
    color: var(--fg-dim);
    font-size: 0.9rem;
    line-height: 1.5;
    white-space: pre;
    overflow-x: auto;
  }

  .output :global(.ok) { color: var(--success); }
  .output :global(.dim) { color: var(--accent-2); }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".cmdline .copy");
  buttons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const cmd = btn.dataset.cmd;
      if (!cmd) return;
      try {
        await navigator.clipboard.writeText(cmd);
        btn.classList.add("copy--ok");
        btn.setAttribute("aria-label", "Copied!");
        setTimeout(() => {
          btn.classList.remove("copy--ok");
          btn.setAttribute("aria-label", "Copy command");
        }, 1400);
      } catch {
        /* clipboard unavailable */
      }
    });
  });
</script>