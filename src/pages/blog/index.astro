---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Base
  title="Dispatches"
  description="Notes from the frontier of agentic commerce, autonomous systems, and real economic infrastructure."
>
  <section class="section">
    <h1>dispatches</h1>
    <p class="section__lede">
      Terminal logs from the Director of Agentic Commerce.
    </p>

    {posts.length > 0 ? (
      <div class="posts">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post">
            <div class="post__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.categories.length > 0 && (
                <span class="cats">{post.data.categories.join(" · ")}</span>
              )}
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read">read dispatch →</span>
          </a>
        ))}
      </div>
    ) : (
      <p>No dispatches yet.</p>
    )}
  </section>
</Base>

<style>
  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .post {
    display: block;
    background: var(--bg-elev);
    border: 1px solid var(--accent-2);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .post:hover {
    border-color: var(--accent);
  }
  .post__meta {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--fg-dim);
    margin-bottom: 0.6rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .post h2 {
    font-family: var(--mono);
    margin: 0.2rem 0 0.6rem;
    color: var(--fg);
    font-size: 1.35rem;
  }
  .post p {
    color: var(--fg-dim);
    margin-bottom: 0.8rem;
  }
  .post .read {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--accent);
  }
  .cats {
    color: var(--accent-2);
  }
</style>